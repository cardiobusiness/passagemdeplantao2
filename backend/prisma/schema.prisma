generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id             Int      @id @default(autoincrement())
  name           String
  document       String?
  email          String?
  phone          String?
  plan           String   @default("trial")
  status         String   @default("trial")
  trialStartsAt  DateTime @default(now())
  trialEndsAt    DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users     UserOrganization[]
  sectors   Sector[]
  beds      Bed[]
  patients  Patient[]
  handovers Handover[]

  @@map("organizations")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  login     String   @unique
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations UserOrganization[]

  @@map("users")
}

model UserOrganization {
  id             Int      @id @default(autoincrement())
  userId         Int
  organizationId Int
  role           String
  jobTitle       String?
  isActive       Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sectors      UserOrganizationSector[]

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("user_organizations")
}

model UserOrganizationSector {
  userOrganizationId Int
  sectorId           Int

  userOrganization UserOrganization @relation(fields: [userOrganizationId], references: [id], onDelete: Cascade)
  sector           Sector           @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@id([userOrganizationId, sectorId])
  @@map("user_organization_sectors")
}

model Sector {
  id             Int      @id @default(autoincrement())
  organizationId Int
  name           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  beds         Bed[]
  userOrganizations UserOrganizationSector[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("sectors")
}

model Bed {
  id             Int      @id @default(autoincrement())
  organizationId Int
  sectorId       Int?
  code           String
  sectorName     String   @default("CTI 1") @map("sector")
  occupied       Boolean  @default(false)
  status         String   @default("Vago") // Vago, Estavel, Atencao, Alta prevista
  isActive       Boolean  @default(true)
  patientId      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sector       Sector?      @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  patient      Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([sectorId])
  @@index([patientId])
  @@map("beds")
}

model Patient {
  id                       Int      @id @default(autoincrement())
  organizationId           Int
  name                     String
  recordNumber             String
  age                      Int
  diagnosis                String
  origin                   String?
  internalTransferLocation String?
  admissionDate            DateTime
  ventilatorySupport       Json?
  mobilityLevel            String?
  reasonForAdmission       String?
  clinicalHistory          Json?
  mechanicalVentilation    Json?
  ventilatorParameters     Json?
  restrictions             Json?
  physiotherapyPlan        Json?
  filterChanges            Json?
  complementaryExams       Json?
  clinicalNotes            String?
  clinicalUpdatedAt        DateTime?
  clinicalUpdatedBy        String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  beds             Bed[]
  admissionMetrics AdmissionMetrics?
  labs             Lab[]
  imaging          Imaging[]
  evolutions       Evolution[]
  alerts           Alert[]

  @@unique([organizationId, recordNumber])
  @@index([organizationId])
  @@map("patients")
}

model AdmissionMetrics {
  id                   Int      @id @default(autoincrement())
  patientId            Int      @unique
  daysInHospital       Int?
  daysInICU            Int?
  daysOnVM             Int?
  daysOnIOT            Int?
  daysOnTQT            Int?
  extubationTime       Int?
  lastFilterChangeDate DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("admission_metrics")
}

model Lab {
  id             Int      @id @default(autoincrement())
  patientId      Int
  date           DateTime
  hb             String?
  ht             String?
  leuco          String?
  bt             String?
  plq            String?
  ur             String?
  cr             String?
  pcr            String?
  na             String?
  k              String?
  ca             String?
  lactate        String?
  extraExamName  String?
  extraExamValue String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("labs")
}

model Imaging {
  id        Int      @id @default(autoincrement())
  patientId Int
  date      DateTime
  type      String
  report    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("imaging")
}

model Evolution {
  id               Int      @id @default(autoincrement())
  patientId        Int
  date             DateTime
  type             String
  description      String
  professionalName String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("evolutions")
}

model Alert {
  id          Int      @id @default(autoincrement())
  patientId   Int
  description String
  severity    String   @default("medium")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model Handover {
  id             Int      @id @default(autoincrement())
  organizationId Int
  professionalId Int
  bedIds         Int[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("handovers")
}
